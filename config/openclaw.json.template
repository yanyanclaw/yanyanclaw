{
  "meta": {
    "lastTouchedVersion": "2026.3.2",
    "lastTouchedAt": "2026-03-13T05:01:51.589Z"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "groq": {
        "baseUrl": "https://api.groq.com/openai/v1",
        "apiKey": "<GROQ_API_KEY>",
        "api": "openai-completions",
        "models": [
          {
            "id": "llama-3.3-70b-versatile",
            "name": "Llama 3.3 70B (Groq)"
          },
          {
            "id": "llama-3.1-8b-instant",
            "name": "Llama 3.1 8B (Groq)"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "groq/llama-3.3-70b-versatile",
        "fallbacks": [
          "google/gemini-2.5-flash",
          "google/gemini-3-flash"
        ]
      },
      "models": {
        "google/gemini-2.5-flash": {},
        "google/gemini-3-flash": {},
        "groq/llama-3.3-70b-versatile": {},
        "groq/llama-3.1-8b-instant": {}
      },
      "workspace": "/root/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "main"
      },
      {
        "id": "stock-manager",
        "name": "Stock Manager",
        "workspace": "/root/.openclaw/workspace-stock",
        "agentDir": "/root/.openclaw/agents/stock-manager"
      },
      {
        "id": "coder",
        "name": "Coder",
        "workspace": "/root/.openclaw/workspace-coder",
        "agentDir": "/root/.openclaw/agents/coder"
      },
      {
        "id": "story-to-html",
        "name": "Story to HTML",
        "workspace": "/root/.openclaw/workspace"
      }
    ]
  },
  "tools": {
    "profile": "full",
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "telegram": [
          "<TELEGRAM_USER_ID>"
        ]
      }
    },
    "exec": {
      "timeoutSec": 60
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": {
          "enabled": true
        },
        "bootstrap-extra-files": {
          "enabled": true
        },
        "command-logger": {
          "enabled": true
        },
        "boot-md": {
          "enabled": true
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "botToken": "<TELEGRAM_BOT_TOKEN>",
      "groupPolicy": "allowlist",
      "streaming": "partial"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "<GATEWAY_AUTH_TOKEN>"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send"
      ]
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  }
}
